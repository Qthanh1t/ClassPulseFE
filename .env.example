# API & WebSocket dùng đường dẫn TƯƠNG ĐỐI — trình duyệt gọi tới Vite dev server,
# Vite proxy forward tới VITE_BACKEND_TARGET. Cookie same-site, chạy được qua IP LAN.
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/ws

# Đích proxy (chỉ Vite dùng, không expose ra browser).
VITE_BACKEND_TARGET=http://localhost:8080
# MinIO object storage (avatar, tài liệu, đính kèm) — phục vụ qua proxy /storage.
VITE_MINIO_TARGET=http://localhost:9000

# TURN server host — set sang IP LAN của Máy A khi test trên hai thiết bị.
VITE_TURN_HOST=localhost
